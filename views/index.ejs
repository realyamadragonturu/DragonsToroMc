<% layout('layout') %>

<div class="header">
    <img src="/logo.png" class="logo" alt="Logo">
    <span class="site-title">Dragons Toro MC</span>
    <% if (isAdmin) { %>
        <a href="/admin" class="admin-btn">+ Đăng Mod</a>
        <a href="/logout" class="admin-btn">Đăng xuất</a>
    <% } else { %>
        <a href="/admin" class="admin-btn">Admin</a>
    <% } %>
</div>

<div class="container">
    <h1 class="welcome-title">📦 Kho Mod Minecraft</h1>
    <div class="mods-grid">
        <% if (mods.length === 0) { %>
            <p class="no-mods">Chưa có mod nào. Hãy đăng nhập admin để thêm mod!</p>
        <% } %>
        <% mods.forEach(mod => { %>
            <div class="mod-card">
                <img src="<%= mod.image %>" class="mod-image" alt="<%= mod.name %>">
                <h3 class="mod-name"><%= mod.name %></h3>
                <p class="mod-description"><%= mod.description %></p>
                <a href="/download/<%= mod.id %>" class="download-btn">📥 Download</a>
                <% if (isAdmin) { %>
                    <a href="/admin/delete/<%= mod.id %>" class="delete-btn" onclick="return confirm('Xóa mod này?')">🗑️ Xóa</a>
                <% } %>
            </div>
        <% }) %>
    </div>
</div>
